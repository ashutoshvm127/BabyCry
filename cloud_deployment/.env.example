# ==============================================================================
# Baby Cry Diagnostic System - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values
# ==============================================================================

# HuggingFace Token (required for model downloads)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kaggle Credentials (optional, for dataset downloads)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Server Configuration
PORT=10000
LOG_LEVEL=INFO

# Model Settings
MODEL_CACHE_DIR=/tmp/model_cache
USE_GPU=false

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Secret Key (auto-generated on Render)
SECRET_KEY=your-secret-key-here

# Redis URL (if using caching)
# REDIS_URL=redis://localhost:6379

# Database URL (if using persistence)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
